# Copy to .env and adjust for your install. All values are optional —
# sane defaults are baked into app/config.py.

# CAMERA_SOURCE=picamera        # or: webcam
# WEBCAM_INDEX=0
# FRAME_WIDTH=450

# EYE_AR_THRESH=0.25
# EYE_AR_CONSEC_FRAMES=15
# YAWN_THRESH=20.0
# YAWN_CONSEC_FRAMES=10

# GPIO_VIBRATION_PIN=8
# GPIO_BUZZER_PIN=10
# ALERT_COOLDOWN_SECONDS=3.0

# SHAPE_PREDICTOR_PATH=models/shape_predictor_68_face_landmarks.dat
# LOG_LEVEL=INFO
